{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "env": {
    "DATABASE_URL": "@database_url",
    "AUTH_SECRET": "@auth_secret",
    "NEXTAUTH_URL": "@nextauth_url"
  },
  "build": {
    "env": {
      "DATABASE_URL": "@database_url",
      "AUTH_SECRET": "@auth_secret",
      "NEXTAUTH_URL": "@nextauth_url"
    }
  },
  "functions": {
    "src/app/**/*.ts": {
      "maxDuration": 10
    },
    "src/actions/**/*.ts": {
      "maxDuration": 10
    }
  }
}